rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /rankings/{rankingId} {
      allow read: if true;

      allow create: if
        request.resource.data.keys().hasOnly([
          'name',
          'difficulty',
          'seconds',
          'userId',
          'createdAt'
        ]) &&
        (!request.resource.data.keys().hasAny(['userId']) ||
          (request.auth != null &&
            request.resource.data.userId == request.auth.uid)) &&
        request.resource.data.name is string &&
        request.resource.data.name.size() >= 1 &&
        request.resource.data.name.size() <= 12 &&
        request.resource.data.difficulty in ['easy', 'normal', 'hard'] &&
        request.resource.data.seconds is number &&
        request.resource.data.seconds > 0 &&
        request.resource.data.seconds < 86400 &&
        request.resource.data.createdAt == request.time;

      allow update, delete: if false;
    }

    match /gameResults/{resultId} {
      allow read: if request.auth != null &&
        resource.data.userId == request.auth.uid;

      allow create: if
        request.auth != null &&
        request.resource.data.keys().hasOnly([
          'userId',
          'difficulty',
          'won',
          'seconds',
          'createdAt'
        ]) &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.difficulty in ['easy', 'normal', 'hard'] &&
        request.resource.data.won is bool &&
        request.resource.data.seconds is number &&
        request.resource.data.seconds > 0 &&
        request.resource.data.seconds < 86400 &&
        request.resource.data.createdAt == request.time;

      allow update, delete: if false;
    }

    match /gameSaves/{userId} {
      allow read, create, update, delete: if
        request.auth != null && request.auth.uid == userId;
    }
  }
}
